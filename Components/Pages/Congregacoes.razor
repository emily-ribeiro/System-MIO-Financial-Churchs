@page "/admin/congregacoes"
@attribute [Authorize(Roles = "Admin")]
@using SistemaIgreja.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Gestão de Congregações</PageTitle>

<div class="container mt-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-building-fill-check me-2 text-primary"></i>Congregações</h2>
        <button class="btn btn-primary shadow-sm fw-bold" @onclick="AbrirModalNovo">
            <i class="bi bi-plus-lg me-2"></i>Nova Congregação
        </button>
    </div>

    <div class="card shadow-sm border-0 animate__animated animate__fadeIn">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4" style="width: 80px;">ID</th>
                            <th>Nome da Congregação</th>
                            <th class="text-center" style="width: 120px;">Status</th>
                            <th class="text-center pe-4" style="width: 150px;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (carregando)
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="spinner-border text-primary"></div>
                                </td>
                            </tr>
                        }
                        else if (!listaCongregacoes.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">Nenhuma congregação cadastrada.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var c in listaCongregacoes)
                            {
                                <tr class="@(c.Ativo ? "" : "table-secondary opacity-75")">
                                    <td class="ps-4 text-muted fw-bold">#@c.Id</td>
                                    <td class="fw-bold @(c.Ativo ? "text-dark" : "text-muted text-decoration-line-through")">@c.Nome</td>
                                    <td class="text-center">
                                        @if (c.Ativo)
                                        {
                                            <span class="badge bg-success shadow-sm"><i class="bi bi-check-circle me-1"></i>Ativa</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary shadow-sm"><i class="bi bi-dash-circle me-1"></i>Inativa</span>
                                        }
                                    </td>
                                    <td class="text-center pe-4">
                                        <button class="btn btn-sm btn-outline-primary me-2 shadow-sm" @onclick="() => AbrirModalEdicao(c)" title="Editar / Alterar Status">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger shadow-sm" @onclick="() => Excluir(c)" title="Excluir Definitivamente">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@*MODAL CADASTRO*@
@if (exibirModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5)" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered shadow-lg">
            <div class="modal-content border-0">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">
                        <i class="bi @(isEdicao ? "bi-pencil-square" : "bi-plus-circle") me-2"></i>
                        @(isEdicao ? "Editar Congregação" : "Nova Congregação")
                    </h5>
                    <button class="btn-close btn-close-white" @onclick="FecharModal"></button>
                </div>
                <div class="modal-body bg-light">
                    @if (!string.IsNullOrEmpty(mensagemErro))
                    {
                        <div class="alert alert-danger py-2 small mb-3 animate__animated animate__shakeX">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@mensagemErro
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nome da Unidade / Congregação</label>
                        <input type="text" class="form-control border-primary" @bind="congregacaoAtual.Nome" @bind:event="oninput" placeholder="Ex: ADBrás Alvorada" />
                    </div>

                    @* REQUISITOS CONGDREGAÇÃO EDIÇÃO *@
                    @if (isEdicao)
                    {
                        <div class="card border-0 shadow-sm mt-4">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0 fw-bold">Status da Congregação</h6>
                                    <small class="text-muted">Unidades inativas não recebem novos lançamentos.</small>
                                </div>
                                <div class="form-check form-switch fs-4 mb-0">
                                    <input class="form-check-input" type="checkbox" role="switch" @bind="congregacaoAtual.Ativo">
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer bg-white">
                    <button class="btn btn-secondary fw-bold" @onclick="FecharModal">Cancelar</button>
                    <button class="btn btn-primary px-4 fw-bold" @onclick="Salvar" disabled="@string.IsNullOrWhiteSpace(congregacaoAtual.Nome)">
                        <i class="bi bi-save me-2"></i>Salvar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Congregacao> listaCongregacoes = new();
    private bool carregando = true;
    
    private bool exibirModal = false;
    private bool isEdicao = false;
    private string mensagemErro = "";
    private Congregacao congregacaoAtual = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarCongregacoes();
    }

    private async Task CarregarCongregacoes()
    {
        carregando = true;
        listaCongregacoes = await Db.Congregacoes.OrderByDescending(c => c.Ativo).ThenBy(c => c.Nome).ToListAsync();
        carregando = false;
    }

    private void AbrirModalNovo()
    {
        congregacaoAtual = new Congregacao { Ativo = true }; // Por padrão nasce ativa
        isEdicao = false;
        mensagemErro = "";
        exibirModal = true;
    }

    private void AbrirModalEdicao(Congregacao c)
    {
        congregacaoAtual = new Congregacao { Id = c.Id, Nome = c.Nome, Ativo = c.Ativo };
        isEdicao = true;
        mensagemErro = "";
        exibirModal = true;
    }

    private void FecharModal() { exibirModal = false; }

    private async Task Salvar()
    {
        if (string.IsNullOrWhiteSpace(congregacaoAtual.Nome))
        {
            mensagemErro = "O nome da congregação é obrigatório.";
            return;
        }

        try
        {
            if (isEdicao)
            {
                var congregacaoExistente = await Db.Congregacoes.FindAsync(congregacaoAtual.Id);
                if (congregacaoExistente != null)
                {
                    congregacaoExistente.Nome = congregacaoAtual.Nome;
                    congregacaoExistente.Ativo = congregacaoAtual.Ativo; // Salva o novo status
                    Db.Congregacoes.Update(congregacaoExistente);
                }
            }
            else
            {
                Db.Congregacoes.Add(congregacaoAtual);
            }

            await Db.SaveChangesAsync();
            await CarregarCongregacoes();
            exibirModal = false;
        }
        catch (Exception ex)
        {
            mensagemErro = $"Erro ao salvar: {ex.InnerException?.Message ?? ex.Message}";
        }
    }

    private async Task Excluir(Congregacao c)
    {
        var temLancamentos = await Db.Lancamentos.AnyAsync(l => l.CongregacaoId == c.Id);
        if (temLancamentos)
        {
            await JS.InvokeVoidAsync("alert", $"Segurança: A congregação '{c.Nome}' possui histórico financeiro e não pode ser excluída.\n\nPor favor, clique em Editar e mude o status para INATIVA.");
            return;
        }

        bool confirmado = await JS.InvokeAsync<bool>("confirm", $"Tem certeza que deseja excluir permanentemente a congregação '{c.Nome}'?");
        if (confirmado)
        {
            Db.Congregacoes.Remove(c);
            await Db.SaveChangesAsync();
            await CarregarCongregacoes();
        }
    }
}