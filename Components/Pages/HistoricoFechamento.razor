@page "/admin/historico-fechamento"
@attribute [Authorize(Roles = "Admin")]
@using SistemaIgreja.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@rendermode InteractiveServer

<PageTitle>Histórico de Fechamentos</PageTitle>

<div class="container mt-4 pb-5" style="max-width: 1000px;">
    @* --- CABEÇALHO --- *@
    <div class="d-flex align-items-center mb-4">
        <div class="bg-primary text-white rounded-3 p-2 me-3 shadow-sm">
            <i class="bi bi-archive-fill fs-4"></i>
        </div>
        <h2 class="mb-0 fw-light">Histórico Anual de <span class="fw-bold">Fechamentos</span></h2>
    </div>

    @* --- FILTROS MINIMALISTAS --- *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <div class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-muted">Congregação</label>
                    <select class="form-select border-0 bg-light rounded-3" @bind="idUnidadeSelecionada">
                        <option value="0">Todas as Congregações (Consolidado)</option>
                        @foreach (var c in listaCongregacoes)
                        {
                            <option value="@c.Id">@c.Nome</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">Ano de Referência</label>
                    <input type="number" class="form-control border-0 bg-light rounded-3" @bind="anoSelecionado" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-dark w-100 rounded-3 shadow-sm py-2" @onclick="CarregarHistorico">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (carregando)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary opacity-25"></div></div>
    }
    else if (historicoMesesFechados != null)
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden animate__animated animate__fadeIn">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4 py-3">Mês</th>
                                <th class="text-end py-3">Entradas</th>
                                <th class="text-end py-3">Saídas</th>
                                <th class="text-end pe-4 py-3">Saldo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!historicoMesesFechados.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted italic">
                                        Nenhum fechamento consolidado encontrado para @anoSelecionado.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var mes in historicoMesesFechados)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <i class="bi bi-check-circle-fill text-success me-2 opacity-75"></i>
                                                <span class="fw-bold">@ObterNomeMes(mes.Mes)</span>
                                            </div>
                                        </td>
                                        <td class="text-end text-success">R$ @mes.Entradas.ToString("N2")</td>
                                        <td class="text-end text-danger">R$ @mes.Saidas.ToString("N2")</td>
                                        <td class="text-end pe-4">
                                            <span class="fw-bold @(mes.Saldo >= 0 ? "text-primary" : "text-warning")">
                                                R$ @mes.Saldo.ToString("N2")
                                            </span>
                                        </td>
                                    </tr>
                                }
                                @* --- RODAPÉ DE TOTAIS --- *@
                                <tr class="bg-light border-top border-2">
                                    <td class="ps-4 py-3 fw-bold text-uppercase small text-muted">Total Acumulado @anoSelecionado</td>
                                    <td class="text-end py-3 fw-bold text-success">R$ @historicoMesesFechados.Sum(x => x.Entradas).ToString("N2")</td>
                                    <td class="text-end py-3 fw-bold text-danger">R$ @historicoMesesFechados.Sum(x => x.Saidas).ToString("N2")</td>
                                    @{
                                        var saldoTotal = historicoMesesFechados.Sum(x => x.Saldo);
                                    }
                                    <td class="text-end pe-4 py-3">
                                        <div class="badge @(saldoTotal >= 0 ? "bg-primary-subtle text-primary" : "bg-danger-subtle text-danger") border-0 px-3 py-2 fs-6">
                                            R$ @saldoTotal.ToString("N2")
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <div class="mt-3 text-end text-muted small pe-2">
            <i class="bi bi-info-circle me-1"></i> Apenas lançamentos com status "Fechado" são contabilizados aqui.
        </div>
    }
</div>

<style>
    .rounded-4 { border-radius: 1rem !important; }
    .italic { font-style: italic; }
    .bg-primary-subtle { background-color: #cfe2ff; }
    .bg-danger-subtle { background-color: #f8d7da; }
    .table-hover tbody tr:hover { background-color: #fbfbfb; }
</style>

@code {
    private List<Congregacao> listaCongregacoes = new();
    private int idUnidadeSelecionada = 0;
    private int anoSelecionado = DateTime.Now.Year;
    private bool carregando = false;
    private List<ResumoMes> historicoMesesFechados = new();

    public class ResumoMes
    {
        public int Mes { get; set; }
        public decimal Entradas { get; set; }
        public decimal Saidas { get; set; }
        public decimal Saldo => Entradas - Saidas;
    }

    protected override async Task OnInitializedAsync()
    {
        listaCongregacoes = await Db.Congregacoes.ToListAsync();
        await CarregarHistorico();
    }

    private string ObterNomeMes(int mes)
    {
        var nome = System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(mes);
        return char.ToUpper(nome[0]) + nome.Substring(1);
    }

    private async Task CarregarHistorico()
    {
        carregando = true;
        var queryAnual = Db.Lancamentos
            .Where(x => x.DataEvento.Year == anoSelecionado && x.Status == "Fechado");

        if (idUnidadeSelecionada > 0)
        {
            queryAnual = queryAnual.Where(x => x.CongregacaoId == idUnidadeSelecionada);
        }

        var lancamentosAnuais = await queryAnual.ToListAsync();

        historicoMesesFechados = lancamentosAnuais
            .GroupBy(x => x.DataEvento.Month)
            .Select(g => new ResumoMes
            {
                Mes = g.Key,
                Entradas = g.Where(x => x.Tipo == "Entrada").Sum(x => x.Valor),
                Saidas = g.Where(x => x.Tipo == "Saida").Sum(x => x.Valor)
            })
            .OrderBy(x => x.Mes)
            .ToList();

        carregando = false;
    }
}