@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@inject NavigationManager NavManager
@inject AppDbContext Db

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="">ADBrás <span class="fw-light">Jaboticabal</span></a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
    <nav class="flex-column nav-scrollable">
        
        @* --- LINKS GERAIS (PARA TODOS LOGADOS) --- *@
        <AuthorizeView>
            <Authorized>
                <div class="nav-item">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="icon-wrapper"><i class="bi bi-house-door-fill"></i></span>
                        <span class="nav-text">Home</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="lancamentos">
                        <span class="icon-wrapper"><i class="bi bi-plus-circle-fill"></i></span>
                        <span class="nav-text">Novo Lançamento</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        @* --- LINKS DO TESOUREIRO --- *@
        <AuthorizeView Roles="Tesoureiro">
            <Authorized>
                <div class="nav-item">
                    <NavLink class="nav-link" href="registro-lancamentos">
                        <span class="icon-wrapper"><i class="bi bi-journal-text"></i></span>
                        <span class="nav-text">Meus Registros</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        @* --- LINKS DO ADMINISTRADOR --- *@
        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="section-label">Administração</div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="admin/congregacoes">
                        <span class="icon-wrapper"><i class="bi bi-building-fill"></i></span>
                        <span class="nav-text">Congregações</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="admin/usuarios">
                        <span class="icon-wrapper"><i class="bi bi-people-fill"></i></span>
                        <span class="nav-text">Usuários</span>
                    </NavLink>
                </div>

                <div class="section-label">Financeiro & Auditoria</div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="admin/lancamentos">
                        <span class="icon-wrapper"><i class="bi bi-pencil-square"></i></span>
                        <span class="nav-text">Gestão Global</span>
                    </NavLink>
                </div>

                @* --- LINK DE REPASSES NO LUGAR CORRETO --- *@
                <div class="nav-item">
                    <NavLink class="nav-link d-flex align-items-center justify-content-between" href="admin/gestao-repasses">
                        <div>
                            <span class="icon-wrapper"><i class="bi bi-arrow-left-right text-warning"></i></span>
                            <span class="nav-text">Gestão de Repasses</span>
                        </div>
                        @* @if (TotalPendentes > 0)
                        {
                            <span class="badge bg-danger rounded-pill shadow-sm animate__animated animate__pulse animate__infinite" style="font-size: 0.75rem;">
                                @TotalPendentes
                            </span>
                        } *@
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="admin/fechamento">
                        <span class="icon-wrapper"><i class="bi bi-shield-lock-fill text-warning"></i></span>
                        <span class="nav-text text-warning fw-bold">Fechamento</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="relatorios">
                        <span class="icon-wrapper"><i class="bi bi-graph-up-arrow"></i></span>
                        <span class="nav-text">Painel Gerencial</span>
                    </NavLink>
                </div>

                @* <div class="nav-item">
                    <NavLink class="nav-link" href="admin/historico-fechamento">
                        <span class="icon-wrapper"><i class="bi bi-archive-fill text-info"></i></span>
                        <span class="nav-text text-info fw-bold">Histórico Anual</span>
                    </NavLink>
                </div> *@
            </Authorized>
        </AuthorizeView>

        @* --- BOTÃO SAIR --- *@
        <AuthorizeView>
            <Authorized>
                <hr class="menu-sep" />
                <div class="nav-item">
                    <button class="nav-link w-100 text-start border-0 bg-transparent" @onclick="Sair">
                        <span class="icon-wrapper"><i class="bi bi-box-arrow-right"></i></span>
                        <span class="nav-text">Sair</span>
                    </button>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private string NavMenuCssClass => collapseNavMenu ? "collapse d-md-block" : "collapse d-md-block show";
    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    [Inject] public ProvedorSessao ProvedorSessao { get; set; } = default!;

    private int TotalPendentes = 0;

    protected override async Task OnInitializedAsync()
    {
        // Conta repasses pendentes agrupando por código de transferência (1 notificação por repasse)
        TotalPendentes = await Db.Lancamentos
            .Where(x => (x.Categoria == "Repasse Matriz" || x.Categoria == "Repasse Recebido")
                        && (x.RepasseStatus == null || x.RepasseStatus == "Pendente"))
            .Select(x => x.CodTransferencia ?? x.Id.ToString())
            .Distinct()
            .CountAsync();
    }

    private async Task Sair()
    {
        await ProvedorSessao.Sair();
        NavManager.NavigateTo("login", true);
    }
}