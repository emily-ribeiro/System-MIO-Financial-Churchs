@inherits LayoutComponentBase

<div class="page">
    @* Sidebar com sombra para destacar do fundo *@
    <div class="sidebar shadow">
        <NavMenu />
    </div>

    <main>
        @* Removemos o link "About" e deixamos uma top-row limpa ou oculta *@
        <div class="top-row px-4 d-none d-md-flex">
            <AuthorizeView>
                <Authorized>
                    <small class="text-muted">Usuário: <strong>@context.User.Identity?.Name</strong></small>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    Ocorreu um erro inesperado.
    <a href="" class="reload">Recarregar</a>
    <a class="dismiss">🗙</a>
</div>