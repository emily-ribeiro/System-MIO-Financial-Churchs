@page "/lancamentos"
@attribute [Authorize(Roles = "Admin, Tesoureiro")]
@using SistemaIgreja.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject AppDbContext Db
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider
@inject ILogger<Lancamentos> Logger
@rendermode InteractiveServer

<PageTitle>Novo Lançamento</PageTitle>

<div class="container mt-4 pb-5">
    <h2 class="mb-4"><i class="bi bi-journal-plus me-2 text-primary"></i>Novo Lançamento</h2>

    <div class="card shadow-sm border-0 bg-light animate__animated animate__fadeIn">
        <div class="card-body p-4">
            @if (!string.IsNullOrEmpty(mensagemErro))
            {
                <div class="alert alert-danger py-2 mb-4 animate__animated animate__shakeX">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@mensagemErro
                </div>
            }
            @if (!string.IsNullOrEmpty(mensagemSucesso))
            {
                <div class="alert alert-success py-2 mb-4">
                    <i class="bi bi-check-circle-fill me-2"></i>@mensagemSucesso
                </div>
            }

            <div class="row g-3">
                @* 1. CONGREGAÇÃO *@
                <div class="col-md-6">
                    <label class="form-label fw-bold">Congregação</label>
                    @if (isAdmin)
                    {
                        <select class="form-select border-primary" @bind="lancamento.CongregacaoId">
                            <option value="0">Selecione a Congregação...</option>
                            @foreach (var c in listaCongregacoes) { <option value="@c.Id">@c.Nome</option> }
                        </select>
                    }
                    else
                    {
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-building"></i></span>
                            <input type="text" class="form-control bg-white fw-bold text-primary border-start-0" value="@nomeMinhaCongregacao" disabled />
                        </div>
                    }
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold">Data do Evento</label>
                    <input type="date" class="form-control" @bind="lancamento.DataEvento" />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold">Tipo</label>
                    <select class="form-select @(lancamento.Tipo == "Entrada" ? "text-success fw-bold" : "text-danger fw-bold")" @bind="lancamento.Tipo">
                        <option value="">Selecione...</option>
                        <option value="Entrada">Entrada (+)</option>
                        <option value="Saida">Saída (-)</option>
                    </select>
                </div>

                @* 2. CATEGORIA *@
                <div class="col-md-4">
                    <label class="form-label fw-bold">Categoria</label>
                    <select class="form-select border-primary" 
                            @bind="lancamento.Categoria"
                            @bind:after="VerificarPreenchimentoAutomatico">
                        <option value="">Selecione...</option>
                        @if (lancamento.Tipo == "Entrada")
                        {
                            <option value="Dízimo">Dízimo</option>
                            <option value="Oferta">Oferta</option>
                            <option value="Cantina">Cantina</option>
                            <option value="Outras Entradas">Outras Entradas</option>
                        }
                        else if (lancamento.Tipo == "Saida")
                        {
                            <option value="Repasse Matriz" class="fw-bold text-primary">📤 Repasse para SEDE</option>

                            <option value="Conta de Luz">Conta de Luz</option>
                            <option value="Conta de Água">Conta de Água</option>
                            <option value="Aluguel">Aluguel</option>
                            <option value="Internet">Internet</option>
                            <option value="Manutenção">Manutenção</option>
                            <option value="Outras Saídas">Outras Saídas</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Forma de Pagamento</label>
                    <select class="form-select" @bind="lancamento.FormaPagamento">
                        <option value="">Selecione...</option>
                        <option value="Dinheiro">Dinheiro Físico</option>
                        <option value="PIX">PIX</option>
                        <option value="Cartão">Cartão</option>
                        @if (lancamento.Tipo == "Saida")
                        {
                            <option value="Boleto">Boleto</option>
                            <option value="A Prazo (Parcelado)">A Prazo (Parcelado)</option>

                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Valor (R$)</label>
                    <input type="number" class="form-control" @bind="lancamento.Valor" />
                </div>

                @* 3. PARCELAMENTO (SAÍDA A PRAZO) *@
                @if (lancamento.Tipo == "Saida" && lancamento.FormaPagamento == "A Prazo (Parcelado)"|| lancamento.FormaPagamento == "Boleto")
                {
                    <div class="col-12 animate__animated animate__fadeIn">
                        <div class="card border-primary bg-white shadow-sm p-3">
                            <label class="form-label fw-bold text-primary">Configurar Parcelamento em Cascata</label>
                            <div class="d-flex align-items-center">
                                <span class="me-2">Gerar este lançamento por</span>
                                <input type="number" class="form-control text-center mx-2" style="width: 80px;" @bind="quantidadeParcelas" min="2" max="60" />
                                <span>meses seguidos.</span>
                            </div>
                        </div>
                    </div>
                }

                <div class="col-12">
                    @* Mostra o aviso de OBRIGATÓRIO se for Outras Saídas OU Outras Entradas *@
                    <label class="form-label fw-bold">
                        Descrição / Observações 
                        @if (lancamento.Categoria == "Outras Saídas" || lancamento.Categoria == "Outras Entradas" || lancamento.Categoria == "Manutenção")
                        {
                            <span class="text-danger ms-1">(OBRIGATÓRIO)</span>
                        }
                    </label>
                    <textarea class="form-control" rows="2" @bind="lancamento.Descricao" placeholder="Descreva os detalhes aqui..."></textarea>
                </div>

                <div class="col-12 text-end mt-4">
                    <button class="btn btn-primary px-5 fw-bold shadow-sm" @onclick="Salvar">
                        <i class="bi bi-save me-2"></i>Registrar Lançamento
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private Lancamento lancamento = new() { DataEvento = DateTime.Today, Status = "Aberto" };
    private List<Congregacao> listaCongregacoes = new();
    private string mensagemErro = "";
    private string mensagemSucesso = "";
    private int quantidadeParcelas = 2;
    private bool isAdmin = false;
    private int minhaCongregacaoId = 0;
    private string nomeMinhaCongregacao = "Carregando...";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isAdmin = user.IsInRole("Admin");

        var emailUser = user.Identity?.Name;
        var usuarioDb = await Db.Usuarios.FirstOrDefaultAsync(u => u.Email == emailUser);
        
        if (usuarioDb != null && usuarioDb.CongregacaoId.HasValue)
        {
            minhaCongregacaoId = usuarioDb.CongregacaoId.Value;
            var cong = await Db.Congregacoes.FindAsync(minhaCongregacaoId);
            nomeMinhaCongregacao = cong?.Nome ?? "Unidade não encontrada";
            lancamento.CongregacaoId = minhaCongregacaoId;
        }

        if (isAdmin) 
        {
            listaCongregacoes = await Db.Congregacoes.Where(c => c.Ativo).OrderBy(c => c.Nome).ToListAsync();
        }
    }

    private async Task Salvar()
    {
    mensagemErro = "";
    mensagemSucesso = "";

    try
    {
        var before = await AuthProvider.GetAuthenticationStateAsync();
        Logger?.LogInformation("Salvar START - User: {user} | DataEvento: {data}", before.User.Identity?.Name ?? "(anon)", lancamento.DataEvento);
    }
    catch (Exception ex)
    {
        Logger?.LogWarning(ex, "Salvar: erro ao obter AuthenticationState antes de salvar.");
    }

    // 1. VALIDAÇÕES DE SEGURANÇA
    if (lancamento.CongregacaoId <= 0) { mensagemErro = "Selecione uma Congregação."; return; }
    if (lancamento.Valor <= 0) { mensagemErro = "O valor deve ser maior que zero."; return; }
    if (string.IsNullOrEmpty(lancamento.Tipo)) { mensagemErro = "Selecione o Tipo (Entrada/Saída)."; return; }
    if (string.IsNullOrEmpty(lancamento.Categoria)) { mensagemErro = "Selecione uma Categoria."; return; }

    // 1.1 VALIDAÇÃO: Descrição obrigatória para categorias específicas
    if ((lancamento.Categoria == "Outras Saídas" || lancamento.Categoria == "Outras Entradas" || lancamento.Categoria == "Manutenção")
        && string.IsNullOrWhiteSpace(lancamento.Descricao))
    {
        mensagemErro = "A descrição é obrigatória para a categoria selecionada.";
        return;
    }

    // --- NOVA TRAVA: REPASSE NÃO PODE SER EM DINHEIRO ---
    if (lancamento.Categoria == "Repasse Matriz")
    {
        if (
            lancamento.FormaPagamento == "PIX" || 
            lancamento.FormaPagamento == "Cartão" || 
            lancamento.FormaPagamento == "A Prazo (Parcelado)" || 
            lancamento.FormaPagamento == "Boleto")
        {
            mensagemErro = "⚠️ Repasse para a SEDE deve feito em Dinheiro.";
            return;
        }
    }

    // 1.5 CHECAGEM: NÃO PERMITIR LANÇAMENTOS EM MESES JÁ FECHADOS
    {
        var mesesParaVerificar = new List<(int Year, int Month, int CongregacaoId)>();

        // Repasse envolve duas unidades (origem e matriz)
        if (lancamento.Categoria == "Repasse Matriz")
        {
            mesesParaVerificar.Add((lancamento.DataEvento.Year, lancamento.DataEvento.Month, lancamento.CongregacaoId));
            mesesParaVerificar.Add((lancamento.DataEvento.Year, lancamento.DataEvento.Month, 4)); // ID 4 = Matriz (ajuste conforme sua base)
        }
        // Parcelamento: verifica cada mês gerado
        else if (lancamento.Tipo == "Saida" &&
                (lancamento.FormaPagamento == "A Prazo (Parcelado)" || lancamento.FormaPagamento == "Boleto") &&
                quantidadeParcelas > 1)
        {
            for (int i = 0; i < quantidadeParcelas; i++)
            {
                var dt = lancamento.DataEvento.AddMonths(i);
                mesesParaVerificar.Add((dt.Year, dt.Month, lancamento.CongregacaoId));
            }
        }
        else
        {
            mesesParaVerificar.Add((lancamento.DataEvento.Year, lancamento.DataEvento.Month, lancamento.CongregacaoId));
        }

        // Verifica existência de qualquer lançamento com Status == "Fechado" no mesmo ano/mês e congregação
        var mesesBloqueados = new List<string>();
        var conjIds = mesesParaVerificar.Select(m => m.CongregacaoId).Distinct().ToList();
        var congs = await Db.Congregacoes.Where(c => conjIds.Contains(c.Id)).ToDictionaryAsync(c => c.Id, c => c.Nome);

        foreach (var m in mesesParaVerificar.Distinct())
        {
            bool fechado = await Db.Lancamentos.AnyAsync(x => x.CongregacaoId == m.CongregacaoId && x.Status == "Fechado" && x.DataEvento.Year == m.Year && x.DataEvento.Month == m.Month);
            if (fechado)
            {
                var nomeCong = congs.ContainsKey(m.CongregacaoId) ? congs[m.CongregacaoId] : (m.CongregacaoId == 4 ? "Matriz" : "Unidade") ;
                var nomeMes = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m.Month);
                mesesBloqueados.Add($"{nomeMes.Substring(0,1).ToUpper()+nomeMes.Substring(1)} {m.Year} ({nomeCong})");
            }
        }

        if (mesesBloqueados.Any())
        {
            mensagemErro = "Não é possível registrar lançamentos em mês(es) já fechado(s): " + string.Join(", ", mesesBloqueados);
            return;
        }
    }

    try
    {
        // --- CENÁRIO A: REPASSE PARA SEDE (Workflow de Aprovação) ---
        if (lancamento.Categoria == "Repasse Matriz")
        {
            string codVinculo = "REP-" + Guid.NewGuid().ToString().Substring(0, 8).ToUpper();

            // Lançamento de Saída na unidade atual (Já nasce Fechado)
            lancamento.Status = "Fechado";
            lancamento.CodTransferencia = codVinculo;
            lancamento.Parcelas = 1;
            Db.Lancamentos.Add(lancamento);

            // Lançamento de Entrada Pendente na Matriz (ID 1)
            var entradaMatriz = new Lancamento {
                CongregacaoId = 4, 
                DataEvento = lancamento.DataEvento,
                Tipo = "Entrada",
                Categoria = "Repasse Recebido",
                Valor = lancamento.Valor,
                FormaPagamento = lancamento.FormaPagamento,
                Descricao = $"Repasse vindo de: {nomeMinhaCongregacao} (Ref: {lancamento.Descricao})",
                RepasseStatus = "Pendente", // Trava para o Admin aprovar
                CodTransferencia = codVinculo,
                Parcelas = 1
            };
            Db.Lancamentos.Add(entradaMatriz);
        }
        // --- CENÁRIO B: PARCELAMENTO EM CASCATA (A Prazo / Boleto) ---
        else if (lancamento.Tipo == "Saida" && 
                (lancamento.FormaPagamento == "A Prazo (Parcelado)" || lancamento.FormaPagamento == "Boleto") && 
                quantidadeParcelas > 1)
        {
            for (int i = 0; i < quantidadeParcelas; i++)
            {
                var p = new Lancamento {
                    CongregacaoId = lancamento.CongregacaoId,
                    DataEvento = lancamento.DataEvento.AddMonths(i),
                    Tipo = lancamento.Tipo,
                    Categoria = lancamento.Categoria,
                    FormaPagamento = lancamento.FormaPagamento,
                    Valor = lancamento.Valor,
                    Descricao = i == 0 ? lancamento.Descricao : $"{lancamento.Descricao} (Mês {i+1}/{quantidadeParcelas})",
                    Status = i == 0 ? "Aberto" : "Agendado", // Primeira aberta, demais agendadas
                    Parcelas = quantidadeParcelas
                };
                Db.Lancamentos.Add(p);
            }
        }
        // --- CENÁRIO C: LANÇAMENTO COMUM ---
        else
        {
            lancamento.Parcelas = 1;
            Db.Lancamentos.Add(lancamento);
        }

        // 2. EFETIVAÇÃO NO BANCO DE DADOS
        await Db.SaveChangesAsync();

        // Após inserir os lançamentos, marque a saída de origem como 'Enviado' (evita bloquear validações anteriores)
        if (lancamento.Categoria == "Repasse Matriz" && !string.IsNullOrEmpty(lancamento.CodTransferencia))
        {
            var origem = await Db.Lancamentos.FirstOrDefaultAsync(x => x.CodTransferencia == lancamento.CodTransferencia && x.Tipo == "Saida" && x.CongregacaoId == lancamento.CongregacaoId);
            if (origem != null)
            {
                origem.RepasseStatus = "Enviado";
                Db.Lancamentos.Update(origem);
                await Db.SaveChangesAsync();
            }
        }

        mensagemSucesso = "Lançamento registrado com sucesso!";

        try
        {
            var after = await AuthProvider.GetAuthenticationStateAsync();
            Logger?.LogInformation("Salvar END - User after save: {user}", after.User.Identity?.Name ?? "(anon)");
        }
        catch (Exception ex)
        {
            Logger?.LogWarning(ex, "Salvar: erro ao obter AuthenticationState após salvar.");
        }

        // 3. LIMPEZA E PREPARAÇÃO PARA O PRÓXIMO REGISTRO
        var ultimaUnidade = lancamento.CongregacaoId;
        var dataUltimoLancamento = lancamento.DataEvento; // usa a data do lançamento que acabou de ser salvo
        lancamento = new Lancamento { 
            CongregacaoId = isAdmin ? ultimaUnidade : minhaCongregacaoId, 
            DataEvento = dataUltimoLancamento, 
            Status = "Aberto",
            Parcelas = 1 
        };
        quantidadeParcelas = 2; // Reset da variável de controle de parcelas
    }
    catch (Exception ex)
    {
        // Pega a mensagem interna (InnerException) para facilitar o seu Debug como QA
        mensagemErro = "Erro ao processar: " + (ex.InnerException?.Message ?? ex.Message);
        Logger?.LogError(ex, "Salvar EXCEPTION - erro ao salvar lançamento.");
    }
    }
    private void VerificarPreenchimentoAutomatico()
{
    if (lancamento.Categoria == "Repasse Matriz")
    {
        // Define PIX automaticamente
        lancamento.FormaPagamento = "Dinheiro";
        
        // Dica de QA: Podemos também limpar a descrição ou sugerir algo
        if (string.IsNullOrEmpty(lancamento.Descricao))
        {
            lancamento.Descricao = "Repasse mensal conforme apuração.";
        }
    }
}
}



