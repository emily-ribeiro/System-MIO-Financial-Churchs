@page "/lancamentos"
@attribute [Authorize(Roles = "Admin, Tesoureiro")]
@using SistemaIgreja.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject AppDbContext Db
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider
@rendermode InteractiveServer

<PageTitle>Novo Lançamento</PageTitle>

<div class="container mt-4 pb-5">
    <h2 class="mb-4"><i class="bi bi-journal-plus me-2 text-primary"></i>Novo Lançamento</h2>

    <div class="card shadow-sm border-0 bg-light animate__animated animate__fadeIn">
        <div class="card-body p-4">
            @if (!string.IsNullOrEmpty(mensagemErro))
            {
                <div class="alert alert-danger py-2 mb-4 animate__animated animate__shakeX">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@mensagemErro
                </div>
            }
            @if (!string.IsNullOrEmpty(mensagemSucesso))
            {
                <div class="alert alert-success py-2 mb-4">
                    <i class="bi bi-check-circle-fill me-2"></i>@mensagemSucesso
                </div>
            }

            <div class="row g-3">
                @* 1. CONGREGAÇÃO *@
                <div class="col-md-6">
                    <label class="form-label fw-bold">Congregação</label>
                    @if (isAdmin)
                    {
                        <select class="form-select border-primary" @bind="lancamento.CongregacaoId">
                            <option value="0">Selecione a Congregação...</option>
                            @foreach (var c in listaCongregacoes) { <option value="@c.Id">@c.Nome</option> }
                        </select>
                    }
                    else
                    {
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-building"></i></span>
                            <input type="text" class="form-control bg-white fw-bold text-primary border-start-0" value="@nomeMinhaCongregacao" disabled />
                        </div>
                    }
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold">Data do Evento</label>
                    <input type="date" class="form-control" @bind="lancamento.DataEvento" />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold">Tipo</label>
                    <select class="form-select @(lancamento.Tipo == "Entrada" ? "text-success fw-bold" : "text-danger fw-bold")" @bind="lancamento.Tipo">
                        <option value="">Selecione...</option>
                        <option value="Entrada">Entrada (+)</option>
                        <option value="Saida">Saída (-)</option>
                    </select>
                </div>

                @* 2. CATEGORIA *@
                <div class="col-md-4">
                    <label class="form-label fw-bold">Categoria</label>
                    <select class="form-select border-primary" @bind="lancamento.Categoria">
                        <option value="">Selecione...</option>
                        @if (lancamento.Tipo == "Entrada")
                        {
                            <option value="Dízimo">Dízimo</option>
                            <option value="Oferta">Oferta</option>
                            <option value="Cantina">Cantina</option>
                            <option value="Outras Entradas">Outras Entradas</option>
                        }
                        else if (lancamento.Tipo == "Saida")
                        {
                            <option value="Conta de Luz">Conta de Luz</option>
                            <option value="Conta de Água">Conta de Água</option>
                            <option value="Aluguel">Aluguel</option>
                            <option value="Internet">Internet</option>
                            <option value="Manutenção">Manutenção</option>
                            <option value="Outras Saídas">Outras Saídas</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Forma de Pagamento</label>
                    <select class="form-select" @bind="lancamento.FormaPagamento">
                        <option value="">Selecione...</option>
                        <option value="Dinheiro">Dinheiro Físico</option>
                        <option value="PIX">PIX</option>
                        <option value="Cartão">Cartão</option>
                        @if (lancamento.Tipo == "Saida")
                        {
                            <option value="Boleto">Boleto</option>
                            <option value="A Prazo (Parcelado)">A Prazo (Parcelado)</option>

                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Valor (R$)</label>
                    <input type="number" class="form-control" @bind="lancamento.Valor" />
                </div>

                @* 3. PARCELAMENTO (SAÍDA A PRAZO) *@
                @if (lancamento.Tipo == "Saida" && lancamento.FormaPagamento == "A Prazo (Parcelado)"|| lancamento.FormaPagamento == "Boleto")
                {
                    <div class="col-12 animate__animated animate__fadeIn">
                        <div class="card border-primary bg-white shadow-sm p-3">
                            <label class="form-label fw-bold text-primary">Configurar Parcelamento em Cascata</label>
                            <div class="d-flex align-items-center">
                                <span class="me-2">Gerar este lançamento por</span>
                                <input type="number" class="form-control text-center mx-2" style="width: 80px;" @bind="quantidadeParcelas" min="2" max="60" />
                                <span>meses seguidos.</span>
                            </div>
                        </div>
                    </div>
                }

                <div class="col-12">
                    @* Mostra o aviso de OBRIGATÓRIO se for Outras Saídas OU Outras Entradas *@
                    <label class="form-label fw-bold">
                        Descrição / Observações 
                        @if (lancamento.Categoria == "Outras Saídas" || lancamento.Categoria == "Outras Entradas" || lancamento.Categoria == "Manutenção")
                        {
                            <span class="text-danger ms-1">(OBRIGATÓRIO)</span>
                        }
                    </label>
                    <textarea class="form-control" rows="2" @bind="lancamento.Descricao" placeholder="Descreva os detalhes aqui..."></textarea>
                </div>

                <div class="col-12 text-end mt-4">
                    <button class="btn btn-primary px-5 fw-bold shadow-sm" @onclick="Salvar">
                        <i class="bi bi-save me-2"></i>Registrar Lançamento
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private Lancamento lancamento = new() { DataEvento = DateTime.Today, Status = "Aberto" };
    private List<Congregacao> listaCongregacoes = new();
    private string mensagemErro = "";
    private string mensagemSucesso = "";
    private int quantidadeParcelas = 2;
    private bool isAdmin = false;
    private int minhaCongregacaoId = 0;
    private string nomeMinhaCongregacao = "Carregando...";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isAdmin = user.IsInRole("Admin");

        var emailUser = user.Identity?.Name;
        var usuarioDb = await Db.Usuarios.FirstOrDefaultAsync(u => u.Email == emailUser);
        
        if (usuarioDb != null && usuarioDb.CongregacaoId.HasValue)
        {
            minhaCongregacaoId = usuarioDb.CongregacaoId.Value;
            var cong = await Db.Congregacoes.FindAsync(minhaCongregacaoId);
            nomeMinhaCongregacao = cong?.Nome ?? "Unidade não encontrada";
            lancamento.CongregacaoId = minhaCongregacaoId;
        }

        if (isAdmin) 
        {
            listaCongregacoes = await Db.Congregacoes.Where(c => c.Ativo).OrderBy(c => c.Nome).ToListAsync();
        }
    }

    private async Task Salvar()
    {
    mensagemErro = "";
    mensagemSucesso = "";

    // Validação de segurança para Admin e Tesoureiro
    if (lancamento.CongregacaoId <= 0)
    {
        mensagemErro = "Por favor, selecione uma Congregação.";
        return;
    }

    if (lancamento.Valor <= 0) { mensagemErro = "O valor deve ser maior que zero."; return; }
    if (string.IsNullOrEmpty(lancamento.Tipo)) { mensagemErro = "Selecione o Tipo."; return; }

    try
    {
        // Se for parcelado ou boleto com múltiplas parcelas
        if (lancamento.Tipo == "Saida" && (lancamento.FormaPagamento == "A Prazo (Parcelado)" || lancamento.FormaPagamento == "Boleto") && quantidadeParcelas > 1)
        {
            for (int i = 0; i < quantidadeParcelas; i++)
            {
                var p = new Lancamento {
                    CongregacaoId = lancamento.CongregacaoId,
                    DataEvento = lancamento.DataEvento.AddMonths(i),
                    Tipo = lancamento.Tipo,
                    Categoria = lancamento.Categoria,
                    FormaPagamento = lancamento.FormaPagamento,
                    Valor = lancamento.Valor,
                    Descricao = i == 0 ? lancamento.Descricao : $"{lancamento.Descricao} (Mês {i+1}/{quantidadeParcelas})",
                    Status = i == 0 ? "Aberto" : "Agendado",
                    // --- CORREÇÃO AQUI ---
                    Parcelas = quantidadeParcelas // Define o total de parcelas
                };
                Db.Lancamentos.Add(p);
            }
        }
        else
        {
            // Lançamento comum (Dinheiro, Pix, etc.)
            // --- CORREÇÃO AQUI ---
            lancamento.Parcelas = 1; // Para lançamentos normais, é sempre 1 parcela
            Db.Lancamentos.Add(lancamento);
        }

        await Db.SaveChangesAsync();
        mensagemSucesso = "Lançamento registrado com sucesso!";
        
        // Reset do objeto mantendo a última congregação se for Admin
        var ultimaCong = lancamento.CongregacaoId;
        lancamento = new Lancamento { 
            CongregacaoId = isAdmin ? ultimaCong : minhaCongregacaoId, 
            DataEvento = DateTime.Today, 
            Status = "Aberto",
            Parcelas = 1 // Garante o valor padrão no novo objeto
        };
    }
    catch (Exception ex) 
    { 
        mensagemErro = "Erro ao salvar: " + (ex.InnerException?.Message ?? ex.Message); 
    }
}
}